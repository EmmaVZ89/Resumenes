<Page x:Class="Resumenes.Ui.Vistas.VistaGenerando"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controles="clr-namespace:Resumenes.Ui.Controles"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      Title="Generando resúmenes">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <vm:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
    <StackPanel MaxWidth="860" Margin="0,8">

      <!-- Encabezado -->
      <TextBlock Text="Generando resúmenes"
                 FontSize="22" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Margin="0,0,0,16"/>

      <!-- ════════════════════════════════════════════════════════════════
           CENTRO: LOADER / PROGRESO DETERMINADO + TEXTO DE ESTADO
           ════════════════════════════════════════════════════════════════ -->
      <ui:Card Margin="0,0,0,16" Padding="24,20">
        <StackPanel HorizontalAlignment="Center">

          <!-- Loader pensante (3 puntos): siempre visible mientras genera -->
          <controles:LoaderPensante
              Estado="{Binding TextoEstado}"
              Activo="True"
              Margin="0,0,0,12"/>

          <!-- Texto de estado -->
          <TextBlock Text="{Binding TextoEstado}"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="600"
                     TextWrapping="Wrap"/>

          <!-- Tema actual: "Tema 2 de 5" -->
          <TextBlock Text="{Binding TextoItem}"
                     FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Visibility="{Binding TextoItem, Converter={x:Static vm:StringToVisibilityConverter.Instancia}}"/>

          <!-- Mensaje de error -->
          <TextBlock Text="{Binding MensajeError}"
                     Foreground="Salmon"
                     Visibility="{Binding MensajeError, Converter={x:Static vm:StringToVisibilityConverter.Instancia}}"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap"/>

        </StackPanel>
      </ui:Card>

      <!-- ════════════════════════════════════════════════════════════════
           LISTA DE TEMAS EN PROCESO
           ════════════════════════════════════════════════════════════════ -->
      <ui:Card Margin="0,0,0,16" Padding="16,12">
        <StackPanel>
          <TextBlock Text="Temas en proceso"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Margin="0,0,0,10"/>

          <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,3" Padding="10,8" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Nombre}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                            Margin="10,0" VerticalAlignment="Center">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="Completado">
                              <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Salteado">
                              <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Error">
                              <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorAttentionBrush}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Estado}" Value="Completado">
                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Estado}" Value="Salteado">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Estado}" Value="Error">
                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Border>

                    <ProgressBar Grid.Column="2"
                                 Value="{Binding Fraccion}"
                                 Minimum="0" Maximum="1"
                                 Height="6"
                                 VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ui:Card>

      <!-- ════════════════════════════════════════════════════════════════
           BARRA GLOBAL + TIEMPO + CANCELAR
           ════════════════════════════════════════════════════════════════ -->
      <ui:Card Margin="0,0,0,16" Padding="16,14">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <ProgressBar Grid.Column="0"
                       Minimum="0" Maximum="1"
                       Value="{Binding FraccionGlobal}"
                       IsIndeterminate="{Binding Indeterminado}"
                       Height="8"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>

          <TextBlock Grid.Column="1"
                     Text="{Binding TextoTiempo}"
                     FontSize="13" FontFamily="Consolas"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"/>

          <ui:Button Grid.Column="2"
                     Content="Cancelar"
                     Command="{Binding CancelarCommand}"
                     Appearance="Secondary"
                     Icon="{ui:SymbolIcon Symbol=Stop24}"/>
        </Grid>
      </ui:Card>

      <!-- Log -->
      <Expander Header="Log de generación" Margin="0,0,0,8">
        <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
          <ItemsControl ItemsSource="{Binding Log}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="NoWrap" Margin="2,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Expander>

    </StackPanel>
  </ScrollViewer>
</Page>
