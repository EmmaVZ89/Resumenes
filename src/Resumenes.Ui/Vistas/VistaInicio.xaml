<Page x:Class="Resumenes.Ui.Vistas.VistaInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Resumenes.Ui.ViewModels"
      Title="Inicio">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <vm:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
    <StackPanel MaxWidth="860" Margin="0,8">

      <!-- ── Aviso de versión nueva (best-effort; oculto si no hay actualización) ── -->
      <ui:Card Padding="16,12" Margin="0,0,0,12"
               Visibility="{Binding HayActualizacion, Converter={StaticResource BoolToVis}}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ui:SymbolIcon Grid.Column="0" Symbol="ArrowDownload24" FontSize="20"
                         VerticalAlignment="Center" Margin="0,0,12,0"
                         Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Hay una versión nueva disponible"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="{Binding MensajeActualizacion}"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
          </StackPanel>
          <ui:Button Grid.Column="2" Content="Descargar"
                     Command="{Binding DescargarActualizacionCommand}"
                     Appearance="Primary"
                     Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                     Margin="0,0,8,0" VerticalAlignment="Center"/>
          <ui:Button Grid.Column="3"
                     Command="{Binding DescartarActualizacionCommand}"
                     Appearance="Secondary"
                     Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                     VerticalAlignment="Center"/>
        </Grid>
      </ui:Card>

      <!-- ── Encabezado: saludo + fecha ── -->
      <ui:Card Padding="24,20" Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock x:Name="TxtSaludo"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBlock x:Name="TxtFecha"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
          </StackPanel>

          <!-- Botón grande Nuevo análisis -->
          <ui:Button Grid.Column="1"
                     Content="Nuevo análisis"
                     Command="{Binding NuevoAnalisisCommand}"
                     Appearance="Primary"
                     Icon="{ui:SymbolIcon Symbol=Add24}"
                     FontSize="14" FontWeight="SemiBold"
                     Height="44" Padding="20,0"
                     VerticalAlignment="Center"/>
        </Grid>
      </ui:Card>

      <!-- ── Historial de análisis ── -->
      <TextBlock Text="Análisis recientes"
                 FontSize="15" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Margin="0,0,0,10"/>

      <!-- Sin análisis -->
      <ui:Card Padding="32,28" Margin="0,0,0,8">
        <ui:Card.Style>
          <Style TargetType="ui:Card">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Analisis.Count}" Value="0">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ui:Card.Style>
        <StackPanel HorizontalAlignment="Center">
          <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="40"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
          <TextBlock Text="No hay análisis todavía."
                     FontSize="14"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     Margin="0,12,0,4"/>
          <TextBlock Text="Hacé clic en 'Nuevo análisis' para empezar."
                     FontSize="12"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </StackPanel>
      </ui:Card>

      <!-- Lista de tarjetas -->
      <ItemsControl ItemsSource="{Binding Analisis}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:AnalisisHistorialVm}">
            <ui:Card Margin="0,0,0,8" Padding="16,14">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Nombre del análisis -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Nombre}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Estado (chip) con color semántico según el estado -->
                <Border Grid.Row="0" Grid.Column="1"
                        CornerRadius="10" Padding="10,4"
                        VerticalAlignment="Center" Margin="10,0,0,0">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Estado}" Value="Completado">
                          <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="En proceso">
                          <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="Con errores">
                          <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Estado}" Value="Completado">
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Estado}" Value="En proceso">
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorAttentionBrush}"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Estado}" Value="Con errores">
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Border>

                <!-- Carpeta + fecha -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Margin="0,6,0,10">
                  <ui:SymbolIcon Symbol="Folder24" FontSize="13"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                 Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding CarpetaOrigen}"
                             FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             TextTrimming="CharacterEllipsis"
                             MaxWidth="400"/>
                  <TextBlock Text=" · " FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                  <TextBlock Text="{Binding FechaLegible}"
                             FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                  <TextBlock Text=" · " FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             Visibility="{Binding TieneCosto, Converter={StaticResource BoolToVis}}"/>
                  <ui:SymbolIcon Symbol="Wallet24" FontSize="13"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                 Margin="0,0,4,0"
                                 Visibility="{Binding TieneCosto, Converter={StaticResource BoolToVis}}"/>
                  <TextBlock Text="{Binding CostoLegible}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             Visibility="{Binding TieneCosto, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Right">

                  <!-- AbrirCarpeta -->
                  <ui:Button Content="Abrir carpeta"
                             Command="{Binding DataContext.AbrirCarpetaCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Secondary"
                             Margin="0,0,6,0"
                             Icon="{ui:SymbolIcon Symbol=FolderOpen24}"/>

                  <!-- Continuar (solo si puede continuar) -->
                  <ui:Button Content="Continuar"
                             Command="{Binding DataContext.ContinuarCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Primary"
                             Margin="0,0,6,0"
                             Icon="{ui:SymbolIcon Symbol=Play24}"
                             Visibility="{Binding PuedeContinuar, Converter={StaticResource BoolToVis}}"/>

                  <!-- Ver resultados (solo si está completo) -->
                  <ui:Button Content="Ver resultados"
                             Command="{Binding DataContext.VerResultadosCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Primary"
                             Margin="0,0,6,0"
                             Icon="{ui:SymbolIcon Symbol=DocumentBulletList24}"
                             Visibility="{Binding EstaCompleto, Converter={StaticResource BoolToVis}}"/>

                  <!-- Eliminar -->
                  <ui:Button Content="Eliminar"
                             Command="{Binding DataContext.EliminarCommand,
                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             CommandParameter="{Binding}"
                             Appearance="Secondary"
                             Icon="{ui:SymbolIcon Symbol=Delete24}"/>
                </StackPanel>
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</Page>
