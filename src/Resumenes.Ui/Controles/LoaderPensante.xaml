<UserControl x:Class="Resumenes.Ui.Controles.LoaderPensante"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="300"
             Loaded="OnLoaded">

  <UserControl.Resources>

    <!-- Animación punto 1: desfase 0 ms -->
    <Storyboard x:Key="AnimPunto1" RepeatBehavior="Forever">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Punto1"
                                     Storyboard.TargetProperty="Opacity">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="0.25"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.4"  Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:0.8"  Value="0.25">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="0.25"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EscalaPunto1"
                                     Storyboard.TargetProperty="ScaleY">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.4"  Value="1.4">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:0.8"  Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="1.0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EscalaPunto1"
                                     Storyboard.TargetProperty="ScaleX">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.4"  Value="1.4">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:0.8"  Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="1.0"/>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Animación punto 2: desfase 250 ms -->
    <Storyboard x:Key="AnimPunto2" RepeatBehavior="Forever">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Punto2"
                                     Storyboard.TargetProperty="Opacity">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="0.25"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0.25"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.65" Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.05" Value="0.25">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="0.25"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EscalaPunto2"
                                     Storyboard.TargetProperty="ScaleY">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.65" Value="1.4">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.05" Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="1.0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EscalaPunto2"
                                     Storyboard.TargetProperty="ScaleX">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.65" Value="1.4">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.05" Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="1.0"/>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Animación punto 3: desfase 500 ms -->
    <Storyboard x:Key="AnimPunto3" RepeatBehavior="Forever">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Punto3"
                                     Storyboard.TargetProperty="Opacity">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="0.25"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5"  Value="0.25"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.9"  Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.3"  Value="0.25">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="0.25"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EscalaPunto3"
                                     Storyboard.TargetProperty="ScaleY">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.9"  Value="1.4">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.3"  Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="1.0"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EscalaPunto3"
                                     Storyboard.TargetProperty="ScaleX">
        <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5"  Value="1.0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.9"  Value="1.4">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.3"  Value="1.0">
          <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
        <EasingDoubleKeyFrame KeyTime="0:0:1.5"  Value="1.0"/>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

  </UserControl.Resources>

  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

    <!-- Tres puntos que pulsan en ola (opacidad + escala) -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">

      <Ellipse x:Name="Punto1" Width="10" Height="10" Margin="5,0"
               Fill="{DynamicResource SystemAccentColorBrush}"
               Opacity="0.25" RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform>
          <ScaleTransform x:Name="EscalaPunto1" ScaleX="1" ScaleY="1"/>
        </Ellipse.RenderTransform>
      </Ellipse>

      <Ellipse x:Name="Punto2" Width="10" Height="10" Margin="5,0"
               Fill="{DynamicResource SystemAccentColorBrush}"
               Opacity="0.25" RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform>
          <ScaleTransform x:Name="EscalaPunto2" ScaleX="1" ScaleY="1"/>
        </Ellipse.RenderTransform>
      </Ellipse>

      <Ellipse x:Name="Punto3" Width="10" Height="10" Margin="5,0"
               Fill="{DynamicResource SystemAccentColorBrush}"
               Opacity="0.25" RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform>
          <ScaleTransform x:Name="EscalaPunto3" ScaleX="1" ScaleY="1"/>
        </Ellipse.RenderTransform>
      </Ellipse>

    </StackPanel>

    <!-- Texto de estado enlazable -->
    <TextBlock x:Name="TextoEstado"
               Text="{Binding Estado, RelativeSource={RelativeSource AncestorType=UserControl}}"
               HorizontalAlignment="Center"
               FontSize="13"
               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
               TextTrimming="CharacterEllipsis"
               MaxWidth="280"/>

  </StackPanel>

</UserControl>
